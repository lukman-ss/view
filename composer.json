{
    "name": "lukman-ss/view",
    "description": "A lightweight PHP view renderer with file lookup, namespaced views, sections, layouts, partials, and escaping helpers.",
    "type": "library",
    "keywords": [
        "view",
        "template",
        "renderer",
        "php"
    ],
    "homepage": "https://github.com/lukman-ss/view",
    "license": "MIT",
    "authors": [
        {
            "name": "Lukman",
            "email": "lukmanumb1@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Lukman\\View\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lukman\\View\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    }
}
